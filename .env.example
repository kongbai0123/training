# Vision Training Studio environment example
#
# Copy to .env only if your launcher or shell explicitly loads .env files.
# The application reads these variables from the process environment.

# Runtime mode: development, production, or prod.
VTS_ENV=development

# Optional portable application root. Leave blank to use the repository/runtime root.
# VTS_APP_HOME=

# Optional user data root. Defaults to the platform app-data location.
# VTS_USER_DATA_DIR=

# Optional projects directory override. Defaults under the user data root.
# VTS_PROJECTS_DIR=

# Optional model directory override. Development and installed builds otherwise
# share the platform app-data model store.
# VTS_MODELS_DIR=

# Optional legacy projects directory used by data migration tools.
# VTS_LEGACY_PROJECTS_DIR=

# Allows selected local filesystem path operations from API calls.
# Keep false unless the user explicitly trusts local paths on this machine.
LOCAL_TRUSTED_MODE=false

# Local session token lifetime in minutes.
VTS_SESSION_TTL_MIN=720
